{
  "version": 1,
  "sandbox_type": "parameter_explorer",
  "visual_theme": "basketball",
  "personal_scene": {
    "setting": "court",
    "primary_prop": "basketball",
    "accent_props": ["headphones", "camera"],
    "mood": "sunset",
    "label": "Your after-school court"
  },
  "title": "Basketball Force Lab",
  "introduction": "Explore how the mass and acceleration of a basketball affect the force required for a pass.",
  "formula_id": "force_equals_mass_times_acceleration",
  "variables": [
    {
      "id": "mass",
      "label": "Basketball mass",
      "unit": "kg",
      "min": 0.4,
      "max": 0.8,
      "step": 0.05,
      "default": 0.6,
      "editable": true
    },
    {
      "id": "acceleration",
      "label": "Acceleration during the pass",
      "unit": "m/s^2",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 8,
      "editable": true
    }
  ],
  "guided_steps": [
    {
      "id": "step-1",
      "instruction": "Change the basketball mass and observe how the force changes.",
      "completion_checks": [{ "type": "value_changed", "variable_id": "mass" }]
    },
    {
      "id": "step-2",
      "instruction": "Increase acceleration and observe how the force changes.",
      "completion_checks": [{ "type": "value_changed", "variable_id": "acceleration" }]
    },
    {
      "id": "step-3",
      "instruction": "Explain the relationship among mass, acceleration, and force.",
      "completion_checks": [{ "type": "reflection_answered", "question_id": "reflection-1" }]
    }
  ],
  "completion_rules": [
    {
      "type": "step_completed",
      "step_id": "step-1"
    },
    {
      "type": "step_completed",
      "step_id": "step-2"
    },
    {
      "type": "reflection_answered",
      "step_id": null
    }
  ],
  "reflection_questions": [
    {
      "id": "reflection-1",
      "question": "What happens to force when acceleration increases while mass stays constant?"
    }
  ],
  "mission": {
    "schema_version": "1.0", "evaluator_version": "numeric-v1", "template_id": "basketball-force-v1",
    "title": "Make the Game-Winning Pass",
    "context": "Use the normalized basketball model to prepare the game-winning pass.",
    "objective": "Produce the target force while keeping the pass settings within the visible limits.",
    "controls": [{ "variable_id": "mass" }, { "variable_id": "acceleration" }],
    "calculated_outputs": [{ "id": "force", "label": "Calculated force", "formula_id": "force_equals_mass_times_acceleration", "unit": "N" }],
    "visible_constraints": [
      { "id": "mass-range", "label": "Ball mass stays realistic", "field": "mass", "operator": "between", "min": 0.55, "max": 0.75 },
      { "id": "acceleration-limit", "label": "Pass acceleration stays controlled", "field": "acceleration", "operator": "less_than_or_equal", "value": 10 },
      { "id": "force-target", "label": "Calculated force reaches the target", "field": "force", "operator": "between", "min": 4.5, "max": 5.2 }
    ],
    "success_condition": { "operator": "AND", "constraint_ids": ["mass-range", "acceleration-limit", "force-target"] },
    "bonus_condition": { "enabled": true, "type": "distinct_second_solution", "description": "Find another valid mass and acceleration combination.", "minimum_difference": { "mass": 0.05, "acceleration": 1 } }
  }
}
