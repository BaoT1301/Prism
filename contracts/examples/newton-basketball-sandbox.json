{
  "version": 1,
  "sandbox_type": "parameter_explorer",
  "visual_theme": "basketball",
  "title": "Basketball Force Lab",
  "introduction": "Explore how the mass and acceleration of a basketball affect the force required for a pass.",
  "formula_id": "force_equals_mass_times_acceleration",
  "variables": [
    {
      "id": "mass",
      "label": "Basketball mass",
      "unit": "kg",
      "min": 0.4,
      "max": 0.8,
      "step": 0.05,
      "default": 0.6,
      "editable": true
    },
    {
      "id": "acceleration",
      "label": "Acceleration during the pass",
      "unit": "m/s^2",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 8,
      "editable": true
    }
  ],
  "guided_steps": [
    {
      "id": "step-1",
      "instruction": "Change the basketball mass and observe how the force changes.",
      "completion_checks": [{ "type": "value_changed", "variable_id": "mass" }]
    },
    {
      "id": "step-2",
      "instruction": "Increase acceleration and observe how the force changes.",
      "completion_checks": [{ "type": "value_increased", "variable_id": "acceleration" }]
    },
    {
      "id": "step-3",
      "instruction": "Explain the relationship among mass, acceleration, and force.",
      "completion_checks": [{ "type": "reflection_answered", "question_id": "reflection-1" }]
    }
  ],
  "completion_rules": [
    {
      "type": "step_completed",
      "step_id": "step-1"
    },
    {
      "type": "step_completed",
      "step_id": "step-2"
    },
    {
      "type": "reflection_answered",
      "step_id": null
    }
  ],
  "reflection_questions": [
    {
      "id": "reflection-1",
      "question": "What happens to force when acceleration increases while mass stays constant?"
    }
  ]
}
