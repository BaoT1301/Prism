{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/sandbox-spec.schema.json",
  "title": "SandboxSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "sandbox_type",
    "title",
    "introduction",
    "formula_id",
    "variables",
    "guided_steps",
    "completion_rules"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "sandbox_type": {
      "enum": [
        "parameter_explorer",
        "graph_lab",
        "guided_activity"
      ]
    },
    "visual_theme": {
      "enum": [
        "basketball",
        "formula1",
        "space"
      ],
      "default": "basketball"
    },
    "personal_scene": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "setting",
        "primary_prop",
        "accent_props",
        "mood",
        "label"
      ],
      "properties": {
        "setting": {
          "enum": [
            "court",
            "racetrack",
            "launchpad",
            "music_room",
            "gaming_desk",
            "art_studio",
            "city_park",
            "workshop",
            "science_lab",
            "kitchen",
            "concert_stage",
            "ocean",
            "mountain_trail",
            "animal_sanctuary",
            "sports_gym",
            "library"
          ]
        },
        "primary_prop": {
          "enum": [
            "basketball",
            "race_car",
            "rocket",
            "guitar",
            "controller",
            "sketchbook",
            "soccer_ball",
            "camera",
            "skateboard",
            "book_stack",
            "headphones",
            "plant",
            "microscope",
            "robot",
            "chef_hat",
            "surfboard",
            "animal_friend",
            "dumbbell",
            "chess_piece",
            "drone",
            "flower",
            "paint_palette",
            "tennis_racket",
            "planet",
            "laptop",
            "baseball"
          ]
        },
        "accent_props": {
          "type": "array",
          "maxItems": 2,
          "items": {
            "enum": [
              "basketball",
              "race_car",
              "rocket",
              "guitar",
              "controller",
              "sketchbook",
              "soccer_ball",
              "camera",
              "skateboard",
              "book_stack",
              "headphones",
              "plant",
              "microscope",
              "robot",
              "chef_hat",
              "surfboard",
              "animal_friend",
              "dumbbell",
              "chess_piece",
              "drone",
              "flower",
              "paint_palette",
              "tennis_racket",
              "planet",
              "laptop",
              "baseball"
            ]
          }
        },
        "mood": {
          "enum": [
            "daylight",
            "sunset",
            "neon",
            "starlight"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 60
        }
      }
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "introduction": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "formula_id": {
      "enum": [
        "force_equals_mass_times_acceleration"
      ]
    },
    "variables": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "unit",
          "min",
          "max",
          "step",
          "default",
          "editable"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{0,39}$"
          },
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "unit": {
            "type": "string",
            "maxLength": 20
          },
          "min": {
            "type": "number"
          },
          "max": {
            "type": "number"
          },
          "step": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "default": {
            "type": "number"
          },
          "editable": {
            "type": "boolean"
          }
        }
      }
    },
    "guided_steps": {
      "type": "array",
      "minItems": 2,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "instruction"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]{0,39}$"
          },
          "instruction": {
            "type": "string",
            "minLength": 1,
            "maxLength": 400
          },
          "completion_checks": {
            "type": "array",
            "maxItems": 4,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "type"
              ],
              "properties": {
                "type": {
                  "enum": [
                    "value_changed",
                    "value_increased",
                    "value_decreased",
                    "reflection_answered"
                  ]
                },
                "variable_id": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "pattern": "^[a-z][a-z0-9_]{0,39}$"
                },
                "question_id": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "pattern": "^[a-z][a-z0-9_-]{0,39}$"
                }
              }
            }
          }
        }
      }
    },
    "completion_rules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "enum": [
              "step_completed",
              "all_steps_completed",
              "reflection_answered"
            ]
          },
          "step_id": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "reflection_questions": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "question"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]{0,39}$"
          },
          "question": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        }
      },
      "default": []
    },
    "mission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "evaluator_version",
        "template_id",
        "title",
        "context",
        "objective",
        "controls",
        "calculated_outputs",
        "visible_constraints",
        "success_condition",
        "bonus_condition"
      ],
      "properties": {
        "schema_version": { "const": "1.0" },
        "evaluator_version": { "const": "numeric-v1" },
        "template_id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{0,80}$" },
        "title": { "type": "string", "minLength": 1, "maxLength": 240 },
        "context": { "type": "string", "minLength": 1, "maxLength": 1600 },
        "objective": { "type": "string", "minLength": 1, "maxLength": 1200 },
        "controls": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["variable_id"],
            "properties": { "variable_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{0,39}$" } }
          }
        },
        "calculated_outputs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "label", "formula_id", "unit"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{0,39}$" },
              "label": { "type": "string", "minLength": 1, "maxLength": 80 },
              "formula_id": { "enum": ["force_equals_mass_times_acceleration"] },
              "unit": { "type": "string", "maxLength": 20 }
            }
          }
        },
        "visible_constraints": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "label", "field", "operator"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{0,39}$" },
              "label": { "type": "string", "minLength": 1, "maxLength": 200 },
              "field": { "type": "string", "pattern": "^[a-z][a-z0-9_]{0,39}$" },
              "operator": { "enum": ["greater_than_or_equal", "less_than_or_equal", "between"] },
              "value": { "type": "number" },
              "min": { "type": "number" },
              "max": { "type": "number" }
            }
          }
        },
        "success_condition": {
          "type": "object",
          "additionalProperties": false,
          "required": ["operator", "constraint_ids"],
          "properties": {
            "operator": { "const": "AND" },
            "constraint_ids": { "type": "array", "minItems": 1, "maxItems": 8, "items": { "type": "string" } }
          }
        },
        "bonus_condition": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "type", "description"],
          "properties": {
            "enabled": { "type": "boolean" },
            "type": { "const": "distinct_second_solution" },
            "description": { "type": "string", "minLength": 1, "maxLength": 400 },
            "minimum_difference": {
              "type": "object",
              "additionalProperties": false,
              "properties": { "mass": { "type": "number" }, "acceleration": { "type": "number" } }
            }
          }
        }
      }
    }
  }
}
