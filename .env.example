# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173
DEMO_MODE=false

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/personalized_learning

# Clerk authentication (backend only; never expose CLERK_SECRET_KEY)
CLERK_JWKS_URL=https://YOUR_CLERK_FRONTEND_API/.well-known/jwks.json
CLERK_ISSUER=https://YOUR_CLERK_FRONTEND_API
CLERK_AUTHORIZED_PARTIES=http://localhost:5173
CLERK_SECRET_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_MODERATION_MODEL=omni-moderation-latest

# Frontend-owned public values; never place secret keys here
VITE_CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY
VITE_API_BASE_URL=http://localhost:8000
