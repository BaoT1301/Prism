# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:3000
DEMO_MODE=false

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/personalized_learning

# Supabase Auth
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1
SUPABASE_AUDIENCE=authenticated

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_MODERATION_MODEL=omni-moderation-latest

# Frontend-owned public values; never place secret/service keys here
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
