{
  "version": 1,
  "sandbox_type": "parameter_explorer",
  "visual_theme": "space",
  "title": "Rocket Force Lab",
  "introduction": "Explore how a rocket's mass and acceleration affect the thrust force required for launch.",
  "formula_id": "force_equals_mass_times_acceleration",
  "variables": [
    { "id": "mass", "label": "Rocket mass", "unit": "kg", "min": 100, "max": 1000, "step": 10, "default": 500, "editable": true },
    { "id": "acceleration", "label": "Launch acceleration", "unit": "m/s^2", "min": 1, "max": 20, "step": 1, "default": 8, "editable": true }
  ],
  "guided_steps": [
    { "id": "step-1", "instruction": "Change the rocket mass and observe how the force changes.", "completion_checks": [{ "type": "value_changed", "variable_id": "mass" }] },
    { "id": "step-2", "instruction": "Change acceleration and observe the thrust force.", "completion_checks": [{ "type": "value_changed", "variable_id": "acceleration" }] },
    { "id": "step-3", "instruction": "Explain the relationship among mass, acceleration, and force.", "completion_checks": [{ "type": "reflection_answered", "question_id": "reflection-1" }] }
  ],
  "completion_rules": [{ "type": "all_steps_completed" }],
  "reflection_questions": [{ "id": "reflection-1", "question": "Why does increasing acceleration increase the required force?" }],
  "mission": {
    "schema_version": "1.0", "evaluator_version": "numeric-v1", "template_id": "space-force-v1",
    "title": "Prepare the Launch",
    "context": "Use the normalized payload model to prepare a controlled launch.",
    "objective": "Produce the target force while staying within the visible launch limits.",
    "controls": [{ "variable_id": "mass" }, { "variable_id": "acceleration" }],
    "calculated_outputs": [{ "id": "force", "label": "Calculated force", "formula_id": "force_equals_mass_times_acceleration", "unit": "N" }],
    "visible_constraints": [
      { "id": "mass-range", "label": "Payload mass setting stays within limits", "field": "mass", "operator": "between", "min": 400, "max": 700 },
      { "id": "acceleration-limit", "label": "Launch acceleration stays controlled", "field": "acceleration", "operator": "less_than_or_equal", "value": 12 },
      { "id": "force-target", "label": "Calculated force reaches the target", "field": "force", "operator": "between", "min": 4000, "max": 7000 }
    ],
    "success_condition": { "operator": "AND", "constraint_ids": ["mass-range", "acceleration-limit", "force-target"] },
    "bonus_condition": { "enabled": true, "type": "distinct_second_solution", "description": "Find another valid mass and acceleration combination.", "minimum_difference": { "mass": 10, "acceleration": 1 } }
  }
}
